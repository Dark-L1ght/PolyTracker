# PolyTracker — Environment Configuration
# Copy this file to .env and fill in your values.

# Your Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Your Telegram user ID (the bot will only respond to you)
CHAT_ID=your_numeric_chat_id_here

# Polymarket API SSL verification (set to "true" to enforce)
# Polymarket's API has a broken SSL cert; disabled by default.
POLYMARKET_VERIFY_SSL=false

# Proxy for Polymarket API requests (if Polymarket is blocked in your country)
# Examples: http://127.0.0.1:7890  or  socks5://127.0.0.1:1080
PROXY_URL=
